          xywh {2 40 203 350} type Select color 2 labelsize 10 align 1 textsize 10
        }
        Fl_Button a_CTEndOfRound {
          label {End Of Round}
          callback {endOfRound();
setCombatDisplay(0);}
          tooltip {Do all the end of round actions. Shows any finished alerts or modifiers} xywh {212 32 90 25} color 211 labelsize 12
        }
        Fl_Button a_CTHelp {
          label HELP
          callback {a_HelpWindow->show();}
          xywh {885 32 74 25} color 6 labelsize 20
        }
        Fl_Button aCB_MoreDetails {
          label {>>}
          callback {if (a_DetailsWindow->shown() != 0) { a_DetailsWindow->hide(); } else { a_DetailsWindow->show(); }}
          tooltip {Show more details about the Initiators and Defenders} xywh {966 31 38 27} deactivate
        }
        Fl_Button a_CombatASpeedInc {
          label {AI++}
          callback {animateSpeed(1);}
          tooltip {Increase animated icon speed} xywh {1011 32 40 25} color 2 labelsize 12
        }
        Fl_Button a_CombatASpeedDec {
          label {AI--}
          callback {animateSpeed(-1);}
          tooltip {Decrease animated icon speed} xywh {1060 32 40 25} color 2 labelsize 12
        }
        Fl_Browser a_CombatMessages {
          label {Combat/Map Messages}
          xywh {2 600 200 116} color 6 labelsize 12 align 1 textsize 10
          code0 {for (int i=0; i<8; i++) { o->add(""); }}
          code1 {o->has_scrollbar(Fl_Browser_::HORIZONTAL);}
          code2 {o->has_scrollbar(0);}
        }
        Fl_Button a_CombatZoomIn {
          label {Z++}
