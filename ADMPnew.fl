          tooltip {Zoom in on the external map} xywh {426 32 46 25} color 2 labelsize 12
        }
        Fl_Button a_CombatXZoomOut {
          label {xZ--}
          callback {doMapMode(-10);}
          tooltip {Zoom out on the external map} xywh {481 32 46 25} color 2 labelsize 12
        }
        Fl_Button a_CombatEnableXWindow {
          label {Show Xm}
          callback {if (a_WExternalGridMap->visible()) { a_WExternalGridMap->hide(); o->label("Show Xm"); }
else { a_WExternalGridMap->show(); o->label("Hide Xm"); }

setWindowTitles();}
          tooltip {Show/Hide External Player Grid Map} xywh {540 32 62 25} color 171 labelsize 12
        }
        Fl_Choice a_CombatDrawMode {
          label {Map Mode}
          callback {doMapMode(o->value());} open
          tooltip {The map mode - select combat or drawing modes} xywh {95 393 106 25} down_box BORDER_BOX labelsize 12 when 6 textsize 12
          code0 {o->add("Combat"); o->add("Freestyle"); o->add("Lines");}
          code1 {o->add("Shapes"); o->add("10' Corridors"); o->add("20' Corridors");}
          code2 {o->add("Copy Object"); o->add("Clear Map Pts");}
          code3 {o->value(0);}
        } {}
