        label {Combat Map}
        callback {//printf("a_TCombat: event %d\\n", Fl::event());} open
        xywh {0 25 1110 700} labelsize 12 resizable
      } {
        Fl_Browser a_CBInitiators {
          label {Action Init Sequence}
