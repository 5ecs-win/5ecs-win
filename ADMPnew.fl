combatGridMap->getGridTile()->setLOSAll();
externalGridMap->getGridTile()->redraw();} open
          tooltip {How far can the players see. If you select 'Fog of War' it becomes very important} xywh {656 33 51 25} down_box BORDER_BOX labelsize 12 textsize 12
          code0 {o->add("5'"); o->add("20'"); o->add("30'"); o->add("60'");}
          code1 {o->add("90'"); o->add("120'");}
