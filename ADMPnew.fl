          tooltip {Zoom in on the DM map} xywh {312 32 46 25} color 6 labelsize 12
        }
        Fl_Button a_CombatZoomOut {
          label {Z--}
          callback {doMapMode(-12);}
          tooltip {Zoom out on the DM map} xywh {367 32 46 25} color 6 labelsize 12
        }
        Fl_Button a_CombatXZoomIn {
