  Fl_Window a_MainWindow {
    label {5eCS Main Window - v5.92 by Zen, copyright 2005+}
    callback {if (Fl::event() == 10) { doSystemExit(); }}
    xywh {676 90 1150 726} type Double labelsize 12 hide resizable
    code0 {\#include "gridMap.h"}
  } {
    Fl_Tabs a_TMain {
      callback {//printf("a_TMain: event %d\\n", Fl::event());} open
      xywh {0 0 1115 725} labelsize 12 align 5
      code0 {\#include "ADMPdata.h"}
      code1 {\#include "ADMPdefines.h"}
      code2 {\#include "ADMPd100MeleeCBSetup.h"}
      code3 {\#include <FL/Fl_Select_Browser.H>}
